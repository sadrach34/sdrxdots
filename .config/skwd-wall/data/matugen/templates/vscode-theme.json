  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "{{colors.outline.default.hex}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "{{colors.primary.default.hex}}"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "{{colors.secondary.default.hex}}"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "{{colors.on_surface_variant.default.hex}}"
      }
    },
    {
      "scope": ["keyword.control", "keyword.control.flow"],
      "settings": {
        "foreground": "{{colors.secondary.default.hex}}"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "{{colors.primary.default.hex}}"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "{{colors.on_surface.default.hex}}"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "{{colors.on_surface_variant.default.hex}}"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "{{colors.secondary.default.hex}}"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "{{colors.on_surface_variant.default.hex}}"
      }
    },
    {
      "scope": ["support.type", "support.constant"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    },
    {
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "{{colors.tertiary.default.hex}}"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "{{colors.primary.default.hex}}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "{{colors.secondary.default.hex}}"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "{{colors.outline.default.hex}}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "{{colors.primary.default.hex}}"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "{{colors.error.default.hex}}"
      }
    }
  ]
}
