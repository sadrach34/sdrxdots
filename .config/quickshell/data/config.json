{
  "_comment": "Main configuration for skwd. Copy this file to config.json and edit to match your setup.",
  "compositor": "hyprland",
  "paths": {
    "scripts": "~/.config/hypr/scripts",
    "cache": "~/.cache/quickshell",
    "wallpaper": "~/Pictures/wallpapers",
    "steamWorkshop": "~/.local/share/Steam/steamapps/workshop/content/431960",
    "steamWeAssets": "~/.local/share/Steam/steamapps/common/wallpaper_engine/assets",
    "steam": "~/.local/share/Steam"
  },
  "monitor": "eDP-1",
  "ollama": {
    "url": "http://localhost:11434",
    "model": "gemma3:4b"
  },
  "matugen": {
    "schemeType": "scheme-fidelity",
    "kdeColorScheme": "SkwdMatugen"
  },
  "integrations": {
    "kitty": "~/.config/kitty/skwd-theme.conf",
    "kde": "~/.local/share/color-schemes/SkwdMatugen.colors",
    "vscode": "~/.vscode/extensions/matugen.matugen-theme-1.0.0/themes/matugen-color-theme.json",
    "vesktop": "~/.config/vesktop/themes/kitty-match.css",
    "zen": "",
    "spicetify": "~/.config/spicetify/Themes/Matugen/color.ini",
    "spicetifyCss": "~/.config/spicetify/Themes/Matugen/user.css",
    "yazi": "~/.config/yazi/theme.toml",
    "qt6ct": "~/.config/qt6ct/colors/matugen.conf"
  },
  "intervals": {
    "weatherPollMs": 600000,
    "wifiPollMs": 10000,
    "smartHomePollMs": 5000,
    "ollamaStatusPollMs": 5000,
    "notificationExpireMs": 8000,
    "systemStatsFastSec": 3,
    "systemStatsSlowSec": 30
  },
  "terminal": "kitty",
  "power": {
    "deviceType": "laptop",
    "profile": "performance"
  },
  "optimization": {
    "enabled": false,
    "toggles": {
      "disableBorders": true,
      "disableTransparency": true,
      "disableAnimations": true,
      "disableBlur": true,
      "disableShadows": true,
      "disableRounding": true,
      "disableGaps": true,
      "disableDimInactive": true,
      "disableQuickshellAnimations": true
    },
    "restoreState": null
  },
  "wallpaperMute": true,
  "components": {
    "bar": {
      "backend": "waybar",
      "waybarConfig": "~/.config/waybar/configs/[TOP] Default",
      "waybarStyle": "~/.config/waybar/style/[Dark] Purpl.css",
      "enabled": true,
      "topPanel": true,
      "dashboard": true,
      "weather": {
        "enabled": false,
        "city": ""
      },
      "wifi": {
        "enabled": false,
        "interface": "enp42s0"
      },
      "bluetooth": true,
      "volume": true,
      "calendar": true,
      "music": {
        "enabled": true,
        "preferredPlayer": "spotify",
        "visualizer": "wave",
        "visualizerTop": true,
        "visualizerBottom": true
      },
      "waybarLayoutPreset": "[TOP] Default",
      "waybarStylePreset": "[Dark] Purpl"
    },
    "lockscreen": false,
    "appLauncher": {
      "enabled": true,
      "backend": "fuzzel"
    },
    "wallpaperSelector": {
      "enabled": true,
      "showColorDots": false,
      "backend": "rofi",
      "autoChangeEnabled": false
    },
    "windowSwitcher": false,
    "powerMenu": {
      "enabled": true,
      "items": [
        {
          "action": "lock",
          "icon": "\uf023",
          "label": ""
        },
        {
          "action": "logout",
          "icon": "\uf2f5",
          "label": ""
        },
        {
          "action": "reboot",
          "icon": "\uf2f9",
          "label": ""
        },
        {
          "action": "poweroff",
          "icon": "\uf011",
          "label": ""
        }
      ]
    },
    "smartHome": false,
    "notifications": true
  },
  "hypridle": {
    "enabled": true,
    "warnMinutes": 9,
    "lockMinutes": 10,
    "ignoreDbusInhibit": false
  },
  "appearance": {
    "colorMode": "dark"
  }
}
